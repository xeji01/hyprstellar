{
    "label" : "logout",
    "action" : "hyprctl dispatch exit 0",
    "text" : "LOGOUT",
    "keybind" : "e"
}

{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "SHUTDOWN",
    "keybind" : "s"
}

{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "SUSPEND",
    "keybind" : "u"
}

{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "REBOOT",
    "keybind" : "r"
}
